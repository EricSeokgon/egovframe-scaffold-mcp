{
  "name": "egovframe-scaffold-mcp",
  "version": "0.6.0",
  "description": "전자정부 표준프레임워크(eGovFrame) 프로젝트 스캐폴딩·공통컴포넌트 조립 MCP 서버 — create/search/add/validate/remove",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "egovframe-scaffold-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "smoke": "node test/smoke.mjs",
    "test:catalog": "node test/catalog.mjs",
    "test:components": "node test/components.mjs",
    "generate:catalog": "node scripts/generate-catalog.mjs",
    "prepublishOnly": "npm run build && npm run test:catalog"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.16",
    "zod": "^3.23.8"
