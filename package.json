  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "egovframe",
    "egovframework",
    "mcp",
    "model-context-protocol",
    "scaffolding",
    "korea",
    "e-government"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricSeokgon/egovframe-scaffold-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/EricSeokgon/egovframe-scaffold-mcp/issues"
  },
  "homepage": "https://github.com/EricSeokgon/egovframe-scaffold-mcp#readme",
  "files": [
    "dist",
    "catalog",
    "README.md",
    "LICENSE"
  ]
}
